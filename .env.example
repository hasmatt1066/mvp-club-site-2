# MVP Club API Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for chat and use case generator)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# === Cohort Signup Flow (AI Summer Camp) ===

# Stripe secret key — get from https://dashboard.stripe.com/test/apikeys (test)
# or https://dashboard.stripe.com/apikeys (live).
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe webhook signing secret. For local dev, this is printed by
# `stripe listen --forward-to localhost:3000/api/stripe-webhook`.
# For deployed environments, copy from the webhook endpoint settings.
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Cohort product ID from the Stripe dashboard (Products → your product → ID).
COHORT_01_PRODUCT_ID=prod_your_id_here

# Resend API key (sending access, scoped to mvpclub.ai). Used by both
# api/stripe-webhook.js and api/waitlist-signup.js to send cohort emails.
# Same value across preview and production. Get from https://resend.com/api-keys.
RESEND_API_KEY=re_your_key_here

# Google service account JSON for Sheets API access.
# Used by src/lib/sheets-client.js to append rows to the Cohort tab of
# mvp-club-master-list. Reuse the same value bizopstool has in its Cloud Run
# env (GOOGLE_SERVICE_ACCOUNT_KEY). Paste the full JSON as a single line —
# the value must start with '{' and end with '}'. Same value across preview
# and production.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
