---
import BaseLayout from './BaseLayout.astro';
import Navigation from '../components/layout/NavigationAstro.astro';
import Footer from '../components/layout/FooterAstro.astro';
import CohortAnnouncementBar from '../components/layout/CohortAnnouncementBar.astro';
import LeadMagnetPopup from '../LeadMagnetPopup.jsx';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  type?: string;
  image?: string;
  jsonLd?: object | object[];
  noLeadMagnet?: boolean;
}

const { noLeadMagnet, ...baseProps } = Astro.props;
---

<BaseLayout {...baseProps}>
  <div class="min-h-screen" style="background-color: var(--color-background); font-family: Inter, system-ui, sans-serif;">
    {!noLeadMagnet && <LeadMagnetPopup client:idle />}
    <CohortAnnouncementBar currentPath={Astro.url.pathname} />
    <Navigation currentPath={Astro.url.pathname} />
    <slot />
    <Footer />
  </div>
</BaseLayout>
