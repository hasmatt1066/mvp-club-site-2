---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/layout/NavigationAstro.astro';
import Footer from '../../components/layout/FooterAstro.astro';
import { getCollection } from 'astro:content';

const learnArticles = (await getCollection('learn'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const hasLearnArticles = learnArticles.length > 0;

const pillars = [
  'Getting Started with AI',
  'AI at Work',
  'AI for [Your Role]',
  'Leading AI at Your Organization',
  'Building with AI',
  'AI Tools and Productivity',
  'AI and Your Career',
  'Human + AI Collaboration',
];

const difficulties = ['beginner', 'intermediate', 'advanced'];

const difficultyColors: Record<string, { bg: string; text: string }> = {
  beginner: { bg: '#e6f4ea', text: '#1e7e34' },
  intermediate: { bg: '#fff3e0', text: '#e65100' },
  advanced: { bg: '#fce4ec', text: '#c62828' },
};
---

<BaseLayout
  title="Resource Library"
  description="Free guides, tutorials, and frameworks for using AI at work. Written by coaches, grounded in practice, built for busy professionals."
  path="/learn"
>
  <div class="min-h-screen" style="background-color: var(--color-background); font-family: Inter, system-ui, sans-serif;">
    <Navigation currentPath="/learn" />

    <!-- Hero -->
    <section class="pt-32 pb-12" style="background-color: var(--color-primary);">
      <div class="max-w-7xl mx-auto px-6">
        <p
          class="text-lg font-semibold uppercase tracking-wider mb-4"
          style="color: var(--color-accent-lifted);"
        >
          Learn
        </p>
        <h1 class="font-display text-4xl md:text-5xl text-white mb-4">
          Resource Library
        </h1>
        <p class="text-lg max-w-2xl" style="color: rgba(255,255,255,0.8);">
          Free guides, tutorials, and frameworks to help you build real AI skills through practice. Written by coaches who do this work every day.
        </p>
      </div>
    </section>

    <!-- Search and Filters -->
    <section class="py-8 border-b" style="background-color: var(--color-surface); border-color: rgba(0,0,0,0.06);">
      <div class="max-w-7xl mx-auto px-6">
        <!-- Search Bar -->
        <div class="mb-6">
          <div class="relative max-w-xl">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              type="text"
              id="search-input"
              placeholder="Search articles by title, topic, or keyword..."
              class="w-full pl-12 pr-4 py-3 rounded-xl border text-sm focus:outline-none focus:ring-2 transition-all"
              style="border-color: rgba(0,0,0,0.1); background-color: var(--color-background); focus:ring-color: var(--color-secondary);"
            />
          </div>
        </div>

        <!-- Pillar Filters -->
        <div class="mb-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">Topic</p>
          <div class="flex flex-wrap gap-2" id="pillar-filters">
            <button
              class="filter-pill filter-pill--active"
              data-pillar="all"
            >
              All Topics
            </button>
            {pillars.map((pillar) => (
              <button
                class="filter-pill"
                data-pillar={pillar}
              >
                {pillar}
              </button>
            ))}
          </div>
        </div>

        <!-- Difficulty Filters -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">Difficulty</p>
          <div class="flex flex-wrap gap-2" id="difficulty-filters">
            <button
              class="filter-pill filter-pill--active"
              data-difficulty="all"
            >
              All Levels
            </button>
            {difficulties.map((diff) => (
              <button
                class="filter-pill"
                data-difficulty={diff}
              >
                {diff.charAt(0).toUpperCase() + diff.slice(1)}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Article Grid -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-6">
        {hasLearnArticles ? (
          <>
            <p class="text-sm text-gray-400 mb-8" id="results-count">
              {learnArticles.length} {learnArticles.length === 1 ? 'article' : 'articles'}
            </p>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="article-grid">
              {learnArticles.map((article) => {
                const formattedDate = new Date(article.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                });
                const diff = article.data.difficulty;
                const diffColor = diff ? difficultyColors[diff] : null;
                const tags = article.data.tags ? article.data.tags.join(' ') : '';
                return (
                  <a
                    href={`/learn/${article.slug}`}
                    class="article-card block bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 group"
                    style="box-shadow: 0 4px 24px rgba(0,0,0,0.06); text-decoration: none;"
                    data-pillar={article.data.pillar}
                    data-difficulty={article.data.difficulty || ''}
                    data-title={article.data.title.toLowerCase()}
                    data-description={article.data.description.toLowerCase()}
                    data-tags={tags.toLowerCase()}
                  >
                    <div class="p-6">
                      <div class="flex items-center gap-2 mb-3 flex-wrap">
                        <span
                          class="text-xs font-semibold uppercase tracking-wider"
                          style="color: var(--color-secondary);"
                        >
                          {article.data.pillar}
                        </span>
                        {diff && diffColor && (
                          <span
                            class="text-xs font-medium px-2 py-0.5 rounded-full"
                            style={`background-color: ${diffColor.bg}; color: ${diffColor.text};`}
                          >
                            {diff.charAt(0).toUpperCase() + diff.slice(1)}
                          </span>
                        )}
                      </div>
                      <h2
                        class="font-display text-xl mb-3 group-hover:opacity-80 transition-opacity"
                        style="color: var(--color-primary);"
                      >
                        {article.data.title}
                      </h2>
                      <p class="text-sm text-gray-500 mb-4 leading-relaxed line-clamp-3">
                        {article.data.description}
                      </p>
                      <div class="flex items-center gap-3 text-xs text-gray-400 flex-wrap">
                        <span>{article.data.author}</span>
                        <span>&middot;</span>
                        <time datetime={article.data.date}>{formattedDate}</time>
                        {article.data.readingTime && (
                          <>
                            <span>&middot;</span>
                            <span>{article.data.readingTime} min read</span>
                          </>
                        )}
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>

            <!-- Empty State (hidden by default) -->
            <div id="empty-state" class="hidden py-12 text-center">
              <div
                class="p-12 rounded-2xl max-w-xl mx-auto"
                style="background-color: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06);"
              >
                <p class="text-lg font-medium mb-2" style="color: var(--color-primary);">
                  No matching articles
                </p>
                <p class="text-gray-500 text-sm">
                  Try a different search term or filter. New content is added regularly.
                </p>
              </div>
            </div>
          </>
        ) : (
          <div class="text-center py-8">
            <div
              class="p-12 rounded-2xl max-w-xl mx-auto mb-12"
              style="background-color: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06);"
            >
              <h2 class="font-display text-2xl mb-4" style="color: var(--color-primary);">
                Coming Soon
              </h2>
              <p class="text-gray-600 mb-6 leading-relaxed">
                We are building a comprehensive library of AI learning resources. Check back soon for guides, tutorials, and frameworks.
              </p>
              <a
                href="/blog"
                class="inline-block px-8 py-4 rounded-lg font-semibold transition-all duration-200 hover:scale-105"
                style="background-color: var(--color-accent); color: white; text-decoration: none;"
              >
                Read the Blog
              </a>
            </div>

            <!-- Show latest blog posts as a bridge -->
            {blogPosts.length > 0 && (
              <>
                <h3 class="font-display text-2xl mb-8" style="color: var(--color-primary);">
                  Latest from the Blog
                </h3>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                  {blogPosts.slice(0, 6).map((post) => {
                    const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    });
                    return (
                      <a
                        href={`/blog/${post.slug}`}
                        class="block bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 group"
                        style="box-shadow: 0 4px 24px rgba(0,0,0,0.06); text-decoration: none;"
                      >
                        <div class="p-6">
                          {post.data.pillar && (
                            <p
                              class="text-xs font-semibold uppercase tracking-wider mb-3"
                              style="color: var(--color-secondary);"
                            >
                              {post.data.pillar}
                            </p>
                          )}
                          <h2
                            class="font-display text-xl mb-3 group-hover:opacity-80 transition-opacity"
                            style="color: var(--color-primary);"
                          >
                            {post.data.title}
                          </h2>
                          {post.data.description && (
                            <p class="text-sm text-gray-500 mb-4 leading-relaxed line-clamp-3">
                              {post.data.description}
                            </p>
                          )}
                          <div class="flex items-center gap-3 text-xs text-gray-400">
                            <span>{post.data.author}</span>
                            <span>&middot;</span>
                            <time datetime={post.data.date}>{formattedDate}</time>
                          </div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </>
            )}
          </div>
        )}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16" style="background-color: var(--color-primary);">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-display text-3xl text-white mb-4">
          Want to go deeper?
        </h2>
        <p class="text-lg mb-8" style="color: rgba(255,255,255,0.8);">
          The Resource Library is just the start. Inside the MVP Club community, you get live coaching, peer support, and hands-on practice with people figuring this out alongside you.
        </p>
        <a
          href="/community"
          class="inline-block px-8 py-4 rounded-lg font-semibold transition-all duration-200 hover:scale-105"
          style="background-color: var(--color-accent); color: white; text-decoration: none;"
        >
          Explore the Community
        </a>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .filter-pill {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background-color: transparent;
    color: #6b7280;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .filter-pill:hover {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  .filter-pill--active {
    background-color: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .filter-pill--active:hover {
    background-color: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
    opacity: 0.9;
  }

  #search-input:focus {
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 3px rgba(56, 178, 172, 0.15);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const pillarFilters = document.getElementById('pillar-filters');
    const difficultyFilters = document.getElementById('difficulty-filters');
    const articleGrid = document.getElementById('article-grid');
    const emptyState = document.getElementById('empty-state');
    const resultsCount = document.getElementById('results-count');

    if (!articleGrid) return; // No articles to filter

    const cards = Array.from(articleGrid.querySelectorAll('.article-card')) as HTMLElement[];
    if (cards.length === 0) return;

    let activePillar = 'all';
    let activeDifficulty = 'all';
    let searchQuery = '';

    function updateFilters() {
      let visibleCount = 0;

      cards.forEach((card) => {
        const pillar = card.dataset.pillar || '';
        const difficulty = card.dataset.difficulty || '';
        const title = card.dataset.title || '';
        const description = card.dataset.description || '';
        const tags = card.dataset.tags || '';

        const matchesPillar = activePillar === 'all' || pillar === activePillar;
        const matchesDifficulty = activeDifficulty === 'all' || difficulty === activeDifficulty;

        let matchesSearch = true;
        if (searchQuery) {
          const q = searchQuery.toLowerCase();
          matchesSearch = title.includes(q) || description.includes(q) || tags.includes(q) || pillar.toLowerCase().includes(q);
        }

        if (matchesPillar && matchesDifficulty && matchesSearch) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
      if (articleGrid) {
        articleGrid.classList.toggle('hidden', visibleCount === 0);
      }
      if (resultsCount) {
        resultsCount.textContent = `${visibleCount} ${visibleCount === 1 ? 'article' : 'articles'}`;
      }
    }

    function setActiveButton(container: HTMLElement, activeValue: string, dataAttr: string) {
      container.querySelectorAll('.filter-pill').forEach((btn) => {
        const el = btn as HTMLElement;
        const val = el.dataset[dataAttr] || '';
        if (val === activeValue) {
          el.classList.add('filter-pill--active');
        } else {
          el.classList.remove('filter-pill--active');
        }
      });
    }

    if (pillarFilters) {
      pillarFilters.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.filter-pill') as HTMLElement | null;
        if (!btn) return;
        activePillar = btn.dataset.pillar || 'all';
        setActiveButton(pillarFilters, activePillar, 'pillar');
        updateFilters();
      });
    }

    if (difficultyFilters) {
      difficultyFilters.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.filter-pill') as HTMLElement | null;
        if (!btn) return;
        activeDifficulty = btn.dataset.difficulty || 'all';
        setActiveButton(difficultyFilters, activeDifficulty, 'difficulty');
        updateFilters();
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        searchQuery = searchInput.value.trim();
        updateFilters();
      });
    }
  });
</script>
