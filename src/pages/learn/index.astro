---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/layout/NavigationAstro.astro';
import Footer from '../../components/layout/FooterAstro.astro';
---

<BaseLayout
  title="Learn"
  description="Free AI learning resources from MVP Club. Guides, tutorials, and frameworks for building real AI skills."
  path="/learn"
>
  <div class="min-h-screen" style="background-color: var(--color-background); font-family: Inter, system-ui, sans-serif;">
    <Navigation currentPath="/learn" />

    <!-- Header -->
    <section class="pt-32 pb-12" style="background-color: var(--color-primary);">
      <div class="max-w-7xl mx-auto px-6">
        <p
          class="text-lg font-semibold uppercase tracking-wider mb-4"
          style="color: var(--color-accent-lifted);"
        >
          Learn
        </p>
        <h1 class="font-display text-4xl md:text-5xl text-white mb-4">
          AI Learning Library
        </h1>
        <p class="text-lg max-w-2xl" style="color: rgba(255,255,255,0.8);">
          Free guides, tutorials, and frameworks to help you build real AI skills through practice.
        </p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div
          class="p-12 rounded-2xl"
          style="background-color: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06);"
        >
          <h2 class="font-display text-2xl mb-4" style="color: var(--color-primary);">
            Coming Soon
          </h2>
          <p class="text-gray-600 mb-8 leading-relaxed">
            We're building a comprehensive library of AI learning resources. In the meantime,
            check out our blog for the latest insights and practical guides.
          </p>
          <a
            href="/blog"
            class="inline-block px-8 py-4 rounded-lg font-semibold transition-all duration-200 hover:scale-105"
            style="background-color: var(--color-accent); color: white; text-decoration: none;"
          >
            Read the Blog
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>
